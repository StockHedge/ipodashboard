# DART OpenAPI 키 (절대 실제 키를 이 파일이나 코드에 커밋하지 마세요)
# https://opendart.fss.or.kr 에서 발급 (비상업용 무료)
DART_API_KEY=your_dart_api_key_here

# 네이버 오픈API 키 — /api/news/search (종목 상세 뉴스 탭)
# https://developers.naver.com/apps 에서 발급 (검색 API 권한 체크)
NAVER_NEWS_CLIENT_ID=your_naver_client_id_here
NAVER_NEWS_CLIENT_SECRET=your_naver_client_secret_here

# 참고: 38.co.kr 스크래핑은 Windows에서 SSL handshake 오류가 자주 발생합니다.
# DART를 주로 사용하고, 38.co.kr은 보조로만 사용하세요.
#
# 이 파일은 예시입니다. 실제 키는 `.env` (gitignore 됨) 에만 두세요.
# 노출된 키는 즉시 해당 서비스에서 폐기 후 재발급 권장.